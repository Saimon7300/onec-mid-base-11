#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Асинх Процедура СогласованнаяСкидкаПриИзменении(Элемент)
	//Начало доработки 30.03.2026
	//Белоусов С.П. Добавление возможности пересчитать/не пересчитывать таблицу
	Если Объект.Товары.Количество() > 0 ИЛИ Объект.Услуги.Количество() > 0 Тогда
		Обещание = ВопросАсинх("Изменен процен скидки. Пересчитать таблицы товаров и услуг?", РежимДиалогаВопрос.ДаНет);
		Результат = Ждать обещание;
		Если Результат = КодВозвратаДиалога.Да Тогда	 
			ПересчитатьТаблицу();
		КонецЕсли;
	КонецЕсли;
	//КонецДоработки
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	//Начало доработки 30.03.2026
	//Белоусов С.П.
	//Исходный код 
	//КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	//ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	//Новый код
	КоэффициентСкидки = 1 - (ТекущиеДанные.Скидка + Объект.СогласованнаяСкидка) / 100;
	МаксимальныйКС = 0;
	Если КоэффициентСкидки <= 0 Тогда
		ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * МаксимальныйКС
	Иначе 
		ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки 
	КонецЕсли;
	РассчитатьСуммуДокумента();
	//Конец доработки
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

