
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	//Начало доработки 29.03.2026
	//Белоусов С.П. Задача Добавить элемент контактное лицо
	//Добавление элемента формы
	ПолеВвода = Элементы.Вставить("КонтактноеЛицо", Тип ("ПолеФормы"),Элементы.Договор.Родитель);
	ПолеВвода.Вид = ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным = "Объект.КонтактноеЛицо";
	
	Элементы.КонтактноеЛицо.СвязиПараметровВыбора = Новый ФиксированныйМассив(Новый массив);
    
	НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.Контрагент");
    НовыйМассив = Новый Массив();
    НовыйМассив.Добавить(НоваяСвязь);
       
    Элементы.КонтактноеЛицо.СвязиПараметровВыбора = Новый ФиксированныйМассив(НовыйМассив);
	//Конец доработки
	
	//Начало доработки 29.03.2026
	//Белоусов С.П. Задача добавить элемент согласованная скидка
	//Добавление элемента формы
	ПолеВвода = Элементы.Вставить("СогласованнаяСкидка", Тип ("ПолеФормы"),Элементы.Организация.Родитель);
	ПолеВвода.Вид = ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным = "Объект.СогласованнаяСкидка";
	//Конец доработки
КонецПроцедуры

